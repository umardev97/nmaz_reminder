rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // users collection
    match /users/{userId} {
      // Allow account creation by the authenticated user for their own uid, or by an admin.
      allow create: if isSignedIn() && (request.auth.uid == userId || isAdmin());

      // Read allowed for owner or admin.
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());

      // Update: owner can update their profile but cannot escalate role to 'admin'. Admins can update anything.
      allow update: if isSignedIn() && (
        isAdmin() ||
        (request.auth.uid == userId && (request.resource.data.role != 'admin'))
      );

      // Delete: owner or admin
      allow delete: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    // prayers structure: /prayers/{uid}/dates/{dateId}
    match /prayers/{userId}/dates/{dateId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isSignedIn() && (request.auth.uid == userId || isAdmin());

      // Optional: ensure prayer boolean fields are booleans when present
      allow create, update: if isSignedIn() && (request.auth.uid == userId || isAdmin()) &&
        request.resource.data.keys().hasAll(['date']) &&
        (!('fajr' in request.resource.data) || request.resource.data.fajr is bool) &&
        (!('dhuhr' in request.resource.data) || request.resource.data.dhuhr is bool) &&
        (!('asr' in request.resource.data) || request.resource.data.asr is bool) &&
        (!('maghrib' in request.resource.data) || request.resource.data.maghrib is bool) &&
        (!('isha' in request.resource.data) || request.resource.data.isha is bool);
    }

    // reports structure: /reports/{uid}/dates/{dateId}
    match /reports/{userId}/dates/{dateId} {
      allow read, write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    // followups metadata stored under users/{uid}/followups/{id}
    match /users/{userId}/followups/{followupId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      // allow marking cancelled by owner or admin
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    // fcm tokens under users/{uid}/fcm/{tokenId}
    match /users/{userId}/fcm/{tokenId} {
      allow create: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    // settings under users/{uid}/settings/{doc}
    match /users/{userId}/settings/{doc} {
      allow read, write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    // daily intentions are created by admins and read by signed-in users.
    match /dailyIntentions/{dateId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // each user can mark their own daily intention complete or incomplete.
    match /users/{userId}/intentions/{dateId} {
      allow read, write, delete: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    // default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
